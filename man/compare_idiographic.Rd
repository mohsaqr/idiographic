% Generated by hand; keep in sync with R/compare.R
\name{compare_idiographic}
\alias{compare_idiographic}
\title{Compare idiographic estimators on one dataset}
\usage{
compare_idiographic(
  data,
  vars,
  estimators = c("var", "graphical_var"),
  id = NULL,
  day = NULL,
  beep = NULL,
  estimator_args = list(),
  keep_fits = FALSE
)
}
\arguments{
\item{data}{A \code{data.frame} or matrix with columns for variables and optional id/day/beep columns.}
\item{vars}{Character vector of variable names.}
\item{estimators}{Character vector naming estimators to fit. Supported values are \code{"var"}, \code{"graphical_var"}, \code{"mlvar"}, \code{"usem"}, and \code{"gimme"}.}
\item{id}{Character. Name of the person-ID column, or \code{NULL}.}
\item{day}{Character. Name of the day/session column, or \code{NULL}.}
\item{beep}{Character. Name of the measurement-occasion column, or \code{NULL}.}
\item{estimator_args}{Named list of per-estimator argument lists.}
\item{keep_fits}{Logical. Store fitted model objects?}
}
\value{
A \code{model_comparison} object with \code{$comparison}, \code{$failures},
and optionally \code{$fits}. \code{$comparison} is a tidy \code{data.frame}
with one row per method/network.
}
\description{
Fits one or more idiographic estimators to the same data and returns a tidy
per-method/per-network comparison table. This is a reporting layer: it does not
define a new model, and each row is computed from the estimator's own
\code{\link[=summary]{summary()}} method plus common edge-table accessors.
}
\examples{
set.seed(1)
d <- data.frame(id = 1, day = rep(1:4, each = 15),
                beep = rep(1:15, 4),
                A = rnorm(60), B = rnorm(60), C = rnorm(60))
cmp <- compare_idiographic(
  d, vars = c("A", "B", "C"), id = "id", day = "day", beep = "beep",
  estimators = c("var", "graphical_var"),
  estimator_args = list(graphical_var = list(n_lambda = 5))
)
cmp$comparison
}
\seealso{
\code{\link[=build_var]{build_var()}}, \code{\link[=graphical_var]{graphical_var()}},
\code{\link[=estimate_stability]{estimate_stability()}}
}
