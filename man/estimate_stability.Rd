% Generated by hand; keep in sync with R/stability.R
\name{estimate_stability}
\alias{estimate_stability}
\title{Estimate edge stability by block resampling}
\usage{
estimate_stability(
  data,
  vars,
  estimator = c("var", "graphical_var", "mlvar", "usem", "gimme"),
  id = NULL,
  day = NULL,
  beep = NULL,
  n_resamples = 100L,
  resample = c("block", "split_half"),
  block_size = NULL,
  threshold = 1e-08,
  seed = NULL,
  keep_fits = FALSE,
  ...
)
}
\arguments{
\item{data}{A \code{data.frame} or matrix with columns for variables and optional id/day/beep columns.}
\item{vars}{Character vector of variable names.}
\item{estimator}{\code{"var"} for \code{\link[=build_var]{build_var()}}, \code{"graphical_var"} for \code{\link[=graphical_var]{graphical_var()}}, \code{"mlvar"} for \code{\link[=build_mlvar]{build_mlvar()}}, \code{"usem"} for \code{\link[=build_usem]{build_usem()}}, or \code{"gimme"} for \code{\link[=build_gimme]{build_gimme()}}.}
\item{id}{Character. Name of the person-ID column, or \code{NULL}.}
\item{day}{Character. Name of the day/session column, or \code{NULL}.}
\item{beep}{Character. Name of the measurement-occasion column, or \code{NULL}.}
\item{n_resamples}{Integer number of bootstrap/split resamples.}
\item{resample}{\code{"block"} samples blocks with replacement; \code{"split_half"} samples half the blocks without replacement on each replicate.}
\item{block_size}{Integer or \code{NULL}. Consecutive block length used only when neither \code{id} nor \code{day} is supplied.}
\item{threshold}{Numeric. Absolute weight above which an edge is counted as selected.}
\item{seed}{Optional integer seed for deterministic resampling.}
\item{keep_fits}{Logical. Store successful resampled fits in the returned object?}
\item{...}{Further arguments passed to the estimator.}
}
\value{
A \code{stability_result} with \code{$stability} edge statistics,
\code{$original} fit, \code{$resample_edges}, \code{$failures}, and
\code{$config}.
}
\description{
Refits an idiographic estimator across deterministic block resamples and
summarizes edge-level stability. Blocks preserve within-block time order:
subject-day blocks when \code{id} and \code{day} are supplied, subjects when
only \code{id} is supplied, days when only \code{day} is supplied, or
consecutive row blocks for a single series. Duplicate blocks receive temporary
ids/day labels before fitting so lag construction never connects two sampled
copies.
}
\examples{
set.seed(1)
d <- data.frame(id = 1, day = rep(1:4, each = 12),
                beep = rep(1:12, 4),
                A = rnorm(48), B = rnorm(48), C = rnorm(48))
st <- estimate_stability(d, vars = c("A", "B", "C"), id = "id",
                         day = "day", beep = "beep",
                         n_resamples = 5, seed = 1)
head(st$stability)
}
\seealso{
\code{\link[=build_var]{build_var()}}, \code{\link[=graphical_var]{graphical_var()}}
}
