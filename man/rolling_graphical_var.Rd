% Generated by hand; keep in sync with R/rolling_graphical_var.R
\name{rolling_graphical_var}
\alias{rolling_graphical_var}
\title{Estimate rolling-window graphical VAR networks}
\usage{
rolling_graphical_var(
  data,
  vars,
  id = NULL,
  day = NULL,
  beep = NULL,
  window_size,
  step = 1L,
  scale = TRUE,
  center_within = TRUE,
  delete_missings = TRUE,
  min_obs = NULL,
  subject = NULL,
  keep_fits = FALSE,
  ...
)
}
\arguments{
\item{data}{A \code{data.frame} or matrix with columns for variables and optional id/day/beep columns.}
\item{vars}{Character vector of variable names.}
\item{id}{Character. Name of the person-ID column, or \code{NULL}.}
\item{day}{Character. Name of the day/session column, or \code{NULL}.}
\item{beep}{Character. Name of the measurement-occasion column, or \code{NULL}.}
\item{window_size}{Integer number of ordered rows per rolling window.}
\item{step}{Integer number of rows to advance between windows.}
\item{scale}{Logical. Whether to standardize variables inside each window.}
\item{center_within}{Logical. Whether to center within person inside each window when more than one id is present.}
\item{delete_missings}{Logical. Drop incomplete current/lagged rows.}
\item{min_obs}{Integer or \code{NULL}. Keep only subjects with at least this many observations before rolling.}
\item{subject}{Optional vector naming the subject(s) to analyse.}
\item{keep_fits}{Logical. Store successful \code{gvar_result} fits?}
\item{...}{Further arguments passed to \code{\link[=graphical_var]{graphical_var()}}, such as \code{n_lambda}, \code{gamma}, \code{lambda_beta}, or \code{lambda_kappa}.}
}
\value{
A \code{rolling_gvar_result} with \code{$estimates}, \code{$windows},
\code{$failures}, and optionally \code{$fits}. \code{$estimates} is a tidy
coefficient table with subject/window metadata plus \code{network},
\code{from}, \code{to}, and \code{weight}.
}
\description{
Fits \code{\link[=graphical_var]{graphical_var()}} over ordered, overlapping
windows within each subject. This is the time-varying graphical VAR companion
to \code{\link[=rolling_var]{rolling_var()}}: every window uses graphical VAR's
lag construction, EBIC/penalty settings, and tidy coefficient access, then
returns one coefficient table per window.
}
\examples{
set.seed(1)
d <- data.frame(id = 1, day = rep(1:5, each = 20),
                beep = rep(1:20, 5),
                A = rnorm(100), B = rnorm(100), C = rnorm(100))
tv <- rolling_graphical_var(d, vars = c("A", "B", "C"), id = "id",
                            day = "day", beep = "beep",
                            window_size = 50, step = 25,
                            scale = FALSE, n_lambda = 5)
head(tv$estimates)
}
\seealso{
\code{\link[=graphical_var]{graphical_var()}}, \code{\link[=rolling_var]{rolling_var()}}
}
