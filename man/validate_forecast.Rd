% Generated by hand; keep in sync with R/forecast.R
\name{validate_forecast}
\alias{validate_forecast}
\title{Validate one-step forecasts from idiographic VAR models}
\usage{
validate_forecast(
  data,
  vars,
  estimator = c("var", "graphical_var"),
  id = NULL,
  day = NULL,
  beep = NULL,
  initial = NULL,
  assess = 1L,
  step = 1L,
  n_splits = NULL,
  block_size = NULL,
  scale = TRUE,
  center_within = TRUE,
  delete_missings = TRUE,
  keep_fits = FALSE,
  ...
)
}
\arguments{
\item{data}{A \code{data.frame} or matrix with columns for variables and optional id/day/beep columns.}
\item{vars}{Character vector of variable names.}
\item{estimator}{\code{"var"} for \code{\link[=build_var]{build_var()}} or \code{"graphical_var"} for \code{\link[=graphical_var]{graphical_var()}}.}
\item{id}{Character. Name of the person-ID column, or \code{NULL}.}
\item{day}{Character. Name of the day/session column, or \code{NULL}.}
\item{beep}{Character. Name of the measurement-occasion column, or \code{NULL}.}
\item{initial}{Integer number of ordered blocks in the first training split.}
\item{assess}{Integer number of blocks to assess per split.}
\item{step}{Integer number of blocks to advance between splits.}
\item{n_splits}{Optional maximum number of rolling splits.}
\item{block_size}{Integer or \code{NULL}. Consecutive block length used only when neither \code{id} nor \code{day} is supplied.}
\item{scale}{Logical. Whether to standardize using training-split means and SDs.}
\item{center_within}{Logical. Whether to center within person using training-split person means when more than one id is present.}
\item{delete_missings}{Logical. Drop incomplete current/lagged assessment rows.}
\item{keep_fits}{Logical. Store fitted split models?}
\item{...}{Further arguments passed to the estimator.}
}
\value{
A \code{forecast_result} with \code{$predictions}, \code{$metrics},
\code{$splits}, \code{$failures}, and optionally \code{$fits}.
}
\description{
Performs rolling-origin one-step prediction from \code{\link[=build_var]{build_var()}}
or \code{\link[=graphical_var]{graphical_var()}}. Each split fits the estimator
on earlier blocks and predicts current variables in the next block from their
lag-1 values. Scaling and within-person centering parameters are learned from
the training split only, then applied to the assessment split before
prediction.
}
\examples{
set.seed(1)
d <- data.frame(id = 1, day = rep(1:5, each = 12),
                beep = rep(1:12, 5),
                A = rnorm(60), B = rnorm(60), C = rnorm(60))
fc <- validate_forecast(d, vars = c("A", "B", "C"), id = "id",
                        day = "day", beep = "beep",
                        initial = 3, n_splits = 2, scale = FALSE)
fc$metrics
}
\seealso{
\code{\link[=build_var]{build_var()}}, \code{\link[=graphical_var]{graphical_var()}},
\code{\link[=estimate_stability]{estimate_stability()}}
}
