% Generated by hand; keep in sync with R/usem.R
\name{build_usem}
\alias{build_usem}
\title{Build a user-specified unified SEM network}
\usage{
build_usem(
  data,
  vars,
  id,
  time = NULL,
  day = NULL,
  beep = NULL,
  min_obs = NULL,
  subject = NULL,
  temporal = c("ar", "all", "none"),
  contemporaneous = c("none", "all"),
  residual_cov = TRUE,
  trim = FALSE,
  trim_alpha = 0.05,
  trim_fit_criteria = 3L,
  cfi_cutoff = 0.95,
  tli_cutoff = 0.95,
  rmsea_cutoff = 0.08,
  srmr_cutoff = 0.08,
  paths = NULL,
  exogenous = NULL,
  standardize = FALSE,
  estimator = "ml",
  seed = NULL
)
}
\arguments{
\item{data}{A \code{data.frame} in long format.}
\item{vars}{Character vector of time-varying variables.}
\item{id}{Character string naming the person-ID column.}
\item{time}{Character string naming the within-person ordering column, or \code{NULL}.}
\item{day}{Character string naming the day/session column, or \code{NULL}.}
\item{beep}{Character string naming the measurement-occasion column, or \code{NULL}.}
\item{min_obs}{Integer or \code{NULL}. Keep only subjects with at least this many observations.}
\item{subject}{Optional vector naming the subject(s) to analyse.}
\item{temporal}{\code{"ar"}, \code{"all"}, \code{"none"}, or lavaan lagged regressions such as \code{"A ~ Blag"}.}
\item{contemporaneous}{\code{"none"}, \code{"all"}, or lavaan current regressions such as \code{"B ~ A"}.}
\item{residual_cov}{Logical. Estimate residual covariances among current endogenous variables?}
\item{trim}{Logical. If \code{TRUE}, use idiographic's clean-room modification-index entry and z-value pruning layer over the declared candidate set.}
\item{trim_alpha}{Significance level used for modification-index entry and z-value pruning when \code{trim = TRUE}.}
\item{trim_fit_criteria}{Number of fit criteria that must pass before forward search stops.}
\item{cfi_cutoff, tli_cutoff, rmsea_cutoff, srmr_cutoff}{Fit thresholds used by trimmed uSEM.}
\item{paths}{Extra lavaan syntax lines to include unchanged.}
\item{exogenous}{Optional subset of \code{vars} to treat as exogenous current variables.}
\item{standardize}{Logical. Standardize variables per person before fitting.}
\item{estimator}{Lavaan estimator. Default \code{"ml"}.}
\item{seed}{Optional random seed.}
}
\value{
A \code{net_usem} object with average temporal, contemporaneous, and residual-covariance networks, per-subject matrices, fit indices, syntax, and tidy coefficients.
}
\description{
Fits person-specific unified Structural Equation Models (uSEM) for intensive
longitudinal data. With \code{trim = FALSE}, the model is fixed by
\code{temporal}, \code{contemporaneous}, \code{residual_cov}, and \code{paths}.
With \code{trim = TRUE}, idiographic uses an independent clean-room
modification-index entry and z-value pruning layer over the declared candidate
set.
}
\seealso{
\code{\link[=build_gimme]{build_gimme()}}, \code{\link[=graphical_var]{graphical_var()}}, \code{\link[=build_mlvar]{build_mlvar()}}
}
